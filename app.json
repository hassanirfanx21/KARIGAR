{
  "expo": {
    "name": "KARIGAR",
    "slug": "karigar-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "karigar",
    "splash": {
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karigar.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.karigar.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
